<%- include("../partial/header") %>

<div class="container py-5">

   <div class="row">
      <div class="col-lg-8 mx-auto">
         <div class="card shadow-sm">
            <div class="card-body p-4">
               <h2 class="mb-4">
                  Edit Form
               </h2>
               <form action="/forms/update/<%= form._id %>" method="post">
               <!-- Form Title -->
               <div class="mb-4">
                
                  <label class="flbl">
                  Form Title
                  </label>
                  <input
                     type="text"
                     name="title"
                     class="fctrl"
                     placeholder="Enter form title"
                     value="<%= form.title %>"
                     required
                     >
               </div>
               <hr>
<div id="questions-container">
   <% form.questions.forEach((question,index)=>{ %>
   <div class="card mb-3 question-card">
      <div class="card-body">
         <h5 class="mb-3">
            Question #<%= index + 1 %>
         </h5>
         <div class="mb-3">
            <label class="flbl">
            Question Text
            </label>
            <input
               type="text"
               class="fctrl"
               name="questions[<%= index %>][questionText]"
               value="<%= question.questionText %>"
               required
               >
         </div>
         <div class="mb-3">
            <label class="flbl">
            Question Type
            </label>
            <select
               class="fctrl question-type"
               name="questions[<%= index %>][questionType]"
               >
               <option
                  value="text"
                  <%= question.questionType === "text" ? "selected" : "" %>>
                  Text
               </option>
               <option
                  value="multiple-choice"
                  <%= question.questionType === "multiple-choice" ? "selected" : "" %>>
                  Multiple Choice
               </option>
               <option
                  value="email"
                  <%= question.questionType === "email" ? "selected" : "" %>>
                  Email
               </option>
               <option
                  value="number"
                  <%= question.questionType === "number" ? "selected" : "" %>>
                  Number
               </option>
            </select>
            <div class="options-container"></div>
         </div>
         <div class="form-check">
            <input
               type="checkbox"
               class="form-check-input"
               name="questions[<%= index %>][isRequired]"
               <%= question.isRequired ? "checked" : "" %>
               >
            <label class="form-check-label">
            Required
            </label>
         </div>
      </div>
   </div>
   <% }) %>
</div>
               <!-- Buttons -->
               <div class="d-flex gap-2 mt-4">
                  <button
                     type="button"
                     id="add-question"
                     class="btn btn-outline-success"
                     >
                  + Add Question
                  </button>
                  
                  <button
                     type="submit"
                     class="btn btn-green"
                     >
                  Save Form
                  </button>

                  
               </div>
            </div>
            </form>
         </div>
      </div>
   </div>

</div>
<script src="/js/createForm.js"></script>
<%- include("../partial/footer") %>